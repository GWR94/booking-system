<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Pending Booking Payment Reminder</title>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f4f9; font-size: 16px; line-height: 1.5; color: #333;">
    {{> header}}

    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #f4f4f9;">
        <tr>
            <td align="center" style="padding: 20px 10px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width: 600px; width: 100%; margin: 0 auto;">
                    <tr>
                        <td style="padding: 20px;">
                            <h1 style="color: #264653; text-align: center; margin: 0 0 24px 0; font-size: 24px; font-weight: bold;">Pending payment reminder</h1>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #ffffff; border: 1px solid #e0e0e0; border-radius: 6px;">
                                <tr>
                                    <td style="padding: 24px;">
                                        <p style="margin: 0 0 12px;">Your booking <strong>#{{bookingId}}</strong> is still waiting for payment.</p>
                                        <p style="margin: 0 0 12px;">Complete checkout before the slot expires at <strong>{{expiresAtFormatted}}</strong>.</p>
                                        <p style="margin: 0;">If you no longer need this booking, no action is required and it will be cancelled automatically.</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 28px auto 0 auto;">
                                <tr>
                                    <td align="center" style="border-radius: 6px; background-color: #2a9d8f;">
                                        <a href="{{resumeUrl}}" style="display: inline-block; padding: 14px 28px; color: #ffffff; text-decoration: none; font-weight: bold; font-size: 16px;">Complete Payment</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    {{> footer}}
</body>
</html>

