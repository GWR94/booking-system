# Copy to .env and configure ONE of the options below.

# Disable interactive tracing prompt (run non-interactively)
# CREWAI_TRACING_ENABLED=false

# --- Option 1: OpenAI (default) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Option 2: Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Option 3: LM Studio (local, no API key) ---
# Requires: LM Studio running with a model loaded, server started (Developer tab)
# LM_STUDIO_MODEL=llama-3.1-8b-instruct
# LM_STUDIO_BASE_URL=http://localhost:1234/v1

# --- Option 4: Ollama (local, no API key) ---
# Requires: ollama run llama3 (or another model)
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434
